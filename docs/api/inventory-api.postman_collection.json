  "item": [
    {
      "name": "auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var timestamp = Date.now();",
                  "pm.environment.set(\"lastRequestTime\", timestamp);",
                  "var email = pm.environment.get(\"adminEmail\") || \"admin@inventory.com\";",
                  "var password = pm.environment.get(\"adminPassword\") || \"Admin123!\";",
                  "pm.request.body.update({",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({",
                  "        email: email,",
                  "        password: password",
                  "    })",
                  "});",
                  "console.log(\"[Pre] ✅ Login: \" + email);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json().data;",
                  "pm.test(\"Login successful\", function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "if(jsonData && jsonData.accessToken) {",
                  "    pm.environment.set(\"accessToken\", jsonData.accessToken);",
                  "    pm.environment.set(\"refreshToken\", jsonData.refreshToken);",
                  "    console.log(\"[Test] ✅ Token: \" + jsonData.accessToken.substring(0, 20) + \"...\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var token = pm.environment.get(\"refreshToken\") || \"\";",
                  "if(!token) {",
                  "    console.log(\"[WARNING] refreshToken no disponible, intentando con accessToken\");",
                  "    token = pm.environment.get(\"accessToken\");",
                  "}",
                  "pm.request.body.update({",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({",
                  "        refreshToken: token",
                  "    })",
                  "});",
                  "console.log(\"[Pre] ✅ Refresh Token\");"
                ],
                "type": "application/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json().data;",
                  "pm.test(\"Refresh successful\", function() {",
                  "    pm.expect([200, 201, 400]).to.include(pm.response.code);",
                  "});",
                  "if(jsonData && jsonData.accessToken) {",
                  "    pm.environment.set(\"accessToken\", jsonData.accessToken);",
                  "    pm.environment.set(\"refreshToken\", jsonData.refreshToken);",
                  "    console.log(\"[Test] ✅ Token renovado\");",
                  "}"
                ],
                "type": "application/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "response": []
        }
      ]
    },
